NEXT_PUBLIC_APP_URL=http://localhost:3000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=ai_saas_dashboard

# Auth
# Generate with: openssl rand -base64 32
AUTH_SECRET=generate-a-random-32-plus-character-secret-before-deploy
ADMIN_EMAILS=admin@example.com,founder@example.com

# File uploads
# Local development can use .storage/uploads.
# Vercel can use /tmp/ai-saas-uploads for temporary files; extracted text is persisted in MongoDB.
# Use Vercel Blob/S3/R2 for durable binary file storage in production.
UPLOAD_STORAGE_DIR=.storage/uploads

# AI provider
AI_PROVIDER=openai
OPENAI_API_KEY=sk_replace_me
OPENAI_MODEL=gpt-4o-mini
AI_PROVIDER_MODEL=gpt-4o-mini

# Stripe
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PRO_PRICE_ID=price_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
